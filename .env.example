# ─────────────────────────────────────────────────────────────
#  Chatur Wealth — Environment Variables
#  Copy this file to .env.local and fill in your real values.
#  NEVER commit .env.local to Git.
# ─────────────────────────────────────────────────────────────

# SMTP Configuration (for contact form email delivery)
# Option A — Gmail (recommended for quick setup):
#   1. Go to myaccount.google.com → Security → 2-Step Verification → App Passwords
#   2. Create an App Password for "Mail"
#   3. Paste it as SMTP_PASS below
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-16-character-app-password

# The email address where enquiries will be delivered
RECIPIENT_EMAIL=deveshchawla@chaturideas.com
